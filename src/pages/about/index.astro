---
import Layout from '../../layouts/Layout.astro';
import BlogShell from '../../components/BlogShell.astro';
import site from '../../../site.config.mjs';

const title = `About — ${site.siteName}`;
const newTab = { target: '_blank', rel: 'noopener noreferrer' } as const;
---

<Layout title={title} description={site.defaultDescription} canonicalPath="/about.html">
	<BlogShell variant="about">
		<div class="content">
			<h2>About</h2>
			<!-- <p>Hi, I'm Askin. This is about text placeholder.</p> -->
			<p>
				<a href="/feed.xml" {...newTab}>RSS Feed</a>
			</p>
			<p>
				<a
					href="https://github.com/UndefinedVoidNull/astro-mix-blog"
					{...newTab}
				>
					Astro Mix Blog
				</a>
			</p>
		</div>
	</BlogShell>
</Layout>
