---
import Layout from '../layouts/Layout.astro';
import BlogEntries from '../components/BlogEntries.astro';
import site from '../../site.config.mjs';

const INDEX_META_DESCRIPTION = 'Askin博客 | 月刊 文章 分享';
const title = `${site.siteName}`;
---

<Layout title={title} description={INDEX_META_DESCRIPTION} canonicalPath="/">
	<BlogEntries pageNum={1} />
</Layout>
